{
  "name": "japanese-database",
  "version": "1.0.0",
  "description": "Jp-Learning — offline Japanese vocabulary trainer (JMdict, flashcards, PT translation)",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "server": "node src/server.js",
    "add": "node src/add.js",
    "quiz": "node src/card.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [],
  "author": "oVesp",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "electron-updater": "^6.3.9",
    "express": "^5.2.1",
    "unofficial-jisho-api": "^2.3.4",
    "wanakana": "^5.3.1"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "sharp": "^0.35.2"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12"
  },
  "build": {
    "appId": "com.ovesp.jplearning",
    "productName": "Jp-Learning",
    "files": [
      "electron/**",
      "src/**",
      "public/**",
      "assets/icon.png",
      "package.json",
      "!data/**",
      "!installer/**",
      "!**/*.original.md"
    ],
    "extraResources": [
      {
        "from": "data/jmdict-index.json",
        "to": "data/jmdict-index.json"
      },
      {
        "from": "data/jmdict-eng.zip",
        "to": "data/jmdict-eng.zip"
      },
      {
        "from": "glossary.json",
        "to": "glossary.json"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Jp-Learning"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "oVesp",
        "repo": "Jp-Learning"
      }
    ]
  }
}
